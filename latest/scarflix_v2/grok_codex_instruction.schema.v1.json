{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jasonos.local/schemas/grok_codex_instruction.schema.v1.json",
  "title": "Grok Codex Instruction Envelope v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "instructions"
  ],
  "properties": {
    "schema_version": {
      "const": "grok_codex_instruction.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "bridge_mode": {
      "type": "string",
      "enum": [
        "REAL_API",
        "LOCAL_FALLBACK",
        "PENDING_HIDDEN_TASK"
      ]
    },
    "fallback_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "instructions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/instruction"
      }
    },
    "strategy_recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendation"
      },
      "default": []
    },
    "autonomy_suggestions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendation"
      },
      "default": []
    },
    "quality_metrics": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "$defs": {
    "instruction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "instruction_id",
        "created_at",
        "expires_at",
        "target_component",
        "risk_level",
        "requires_user_decision",
        "approved_for_codex_execution",
        "success_criteria",
        "retry_policy"
      ],
      "properties": {
        "instruction_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "target_component": {
          "type": "string",
          "enum": [
            "status_reporting",
            "dashboard",
            "scarflix_materialized_expansion",
            "qa_orchestration",
            "autonomy_loop",
            "documentation"
          ]
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "requires_user_decision": {
          "type": "boolean"
        },
        "approved_for_codex_execution": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "retry_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "max_attempts"
          ],
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "retry_delay_seconds": {
              "type": "integer",
              "minimum": 0
            },
            "backoff_strategy": {
              "type": "string"
            },
            "on_failure": {
              "type": "string"
            }
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_type"
      ],
      "properties": {
        "action_type": {
          "type": "string",
          "enum": [
            "write_status_summary",
            "write_strategy_note",
            "queue_detached_task_request",
            "update_dashboard_note",
            "update_next_actions"
          ]
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "summary"
      ],
      "properties": {
        "recommendation_id": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unspecified"
          ]
        },
        "target_component": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
