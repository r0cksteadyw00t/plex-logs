{
  "schema": "scarflix_foundry_task_v1",
  "required": ["id", "mission", "objective", "risk", "allowed_actions", "definition_of_done"],
  "fields": {
    "id": "Unique task id",
    "mission": "Mission id, e.g. ScarFLIX Mission 001",
    "objective": "Outcome to achieve",
    "context_files": "GitHub paths or telemetry files",
    "risk": "low | medium | high",
    "allowed_actions": "Allow-listed local actions",
    "blocked_actions": "Actions not permitted",
    "definition_of_done": "Task-level completion criteria",
    "stop_conditions": "Conditions requiring ATTN_USER_REQUIRED",
    "result_paths": "Expected output paths in plex-logs"
  }
}
