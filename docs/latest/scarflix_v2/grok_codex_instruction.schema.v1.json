{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/r0cksteadyw00t/plex-logs/main/latest/scarflix_v2/grok_codex_instruction.schema.v1.json",
  "title": "Grok-Codex Instruction Envelope v1",
  "type": "object",
  "required": [
    "schema_version",
    "component",
    "updated_utc",
    "source",
    "instructions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "grok_codex_instruction.v1"
    },
    "component": {
      "const": "jasonos_prime_grok_instruction_bridge"
    },
    "updated_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "grok_api",
        "local_only_no_token",
        "local_status_fallback",
        "manual_grok_response"
      ]
    },
    "human_summary": {
      "type": "string"
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/instruction"
      }
    }
  },
  "$defs": {
    "instruction": {
      "type": "object",
      "required": [
        "instruction_id",
        "created_at",
        "expires_at",
        "target_component",
        "risk_level",
        "requires_user_decision",
        "approved_for_codex_execution",
        "success_criteria",
        "retry_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "instruction_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 120,
          "pattern": "^[A-Za-z0-9_.:-]+$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "target_component": {
          "type": "string",
          "enum": [
            "scarflix_materialized_pipeline",
            "scarflix_qa",
            "jasonos_prime",
            "public_mirror",
            "status_dashboard",
            "worker_mesh",
            "grok_codex_bridge",
            "documentation"
          ]
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "requires_user_decision": {
          "type": "boolean"
        },
        "approved_for_codex_execution": {
          "type": "boolean"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "default": []
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "retry_policy": {
          "type": "object",
          "required": [
            "max_attempts",
            "backoff_seconds",
            "escalate_after_attempts"
          ],
          "additionalProperties": false,
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            },
            "backoff_seconds": {
              "type": "integer",
              "minimum": 0,
              "maximum": 86400
            },
            "escalate_after_attempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            },
            "escalation_target": {
              "type": "string",
              "enum": [
                "none",
                "grok_handoff",
                "jason"
              ],
              "default": "grok_handoff"
            }
          }
        },
        "evidence_required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "source_handoff_path": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "action": {
      "type": "object",
      "required": [
        "action_type"
      ],
      "additionalProperties": false,
      "properties": {
        "action_type": {
          "type": "string",
          "enum": [
            "status_only",
            "publish_status_summary",
            "start_detached_task"
          ]
        },
        "task_name": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
